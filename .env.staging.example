# InsureFlow — ambiente STAGING (pré-produção)
# Copie: cp .env.staging.example .env.staging

APP_ENV=staging
NODE_ENV=production

# Neon staging branch
DATABASE_URL=postgresql://USER:PASSWORD@ep-STAGING-pooler.neon.tech/insureflow?sslmode=require
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-STAGING.neon.tech/insureflow?sslmode=require

REDIS_URL=redis://default:PASSWORD@redis-staging:6379

JWT_SECRET=REPLACE_WITH_STAGING_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

PORT=4000
CORS_ORIGIN=https://staging.insureflow.app
THROTTLE_TTL=60
THROTTLE_LIMIT=100

AUTH_SECRET=REPLACE_WITH_STAGING_AUTH_SECRET_MIN_32_CHARS
API_INTERNAL_URL=https://api-staging.insureflow.app

# Sprint 2 — leads ownership (HML: shadow; produção: off)
OWNERSHIP_ENFORCEMENT=shadow

# Nunca seed demo em staging
SEED_DEV_DATA=0
