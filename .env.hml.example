# InsureFlow — template HML Sprint 2 (Neon dev + Railway + Vercel preview)
# NÃO usar credenciais de produção.
# Copie valores reais para Railway/Vercel dashboards (não commitar secrets).

APP_ENV=development

# Neon HML (mesmo branch dev ou branch staging dedicado)
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-pooler.region.aws.neon.tech/insureflow?sslmode=require
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-XXXX.region.aws.neon.tech/insureflow?sslmode=require

REDIS_URL=redis://default:PASSWORD@redis.railway.internal:6379

JWT_SECRET=REPLACE_HML_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

PORT=4000
# Após deploy Vercel HML — incluir URL exata do preview
CORS_ORIGIN=https://insureflow-web-dev.vercel.app,http://localhost:3000

# Sprint 2 — shadow em HML; produção permanece off
OWNERSHIP_ENFORCEMENT=shadow

THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Vercel (Preview / HML)
AUTH_SECRET=REPLACE_HML_AUTH_MIN_32_CHARS
API_INTERNAL_URL=https://insureflow-api-dev.up.railway.app
API_URL=https://insureflow-api-dev.up.railway.app

SEED_DEV_DATA=1
