# InsureFlow — ambiente LOCAL (máquina do desenvolvedor)
# Copie: cp .env.local.example .env.local

APP_ENV=local
NODE_ENV=development

# PostgreSQL (docker compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insureflow?schema=public

# Redis (docker compose)
REDIS_URL=redis://127.0.0.1:6379

# JWT — API
JWT_SECRET=dev-secret-min-32-chars-long-change-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

# API
PORT=4000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Next.js — sessão + BFF
AUTH_SECRET=dev-auth-secret-min-32-chars-change-prod
API_INTERNAL_URL=http://localhost:4000

# Seed CRM demo após seed base
SEED_DEV_DATA=1

# Storage (futuro — não obrigatório)
# STORAGE_PROVIDER=local

# Debug (opcional)
# DEAL_CONTRACT_DEBUG=1
# RUNTIME_AUDIT=1
