# InsureFlow — ambiente PRODUCTION
# Copie: cp .env.production.example .env.production
# Configure secrets via Railway / Vercel dashboards — não commitar valores reais.

APP_ENV=production
NODE_ENV=production

# Neon production branch
DATABASE_URL=postgresql://USER:PASSWORD@ep-PROD-pooler.neon.tech/insureflow?sslmode=require
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-PROD.neon.tech/insureflow?sslmode=require

REDIS_URL=redis://default:PASSWORD@redis-prod:6379

JWT_SECRET=REPLACE_WITH_PRODUCTION_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

PORT=4000
# Produção — corretoraavila.com.br (apex + www; acrescente homolog quando existir)
CORS_ORIGIN=https://corretoraavila.com.br,https://www.corretoraavila.com.br
THROTTLE_TTL=60
THROTTLE_LIMIT=100

AUTH_SECRET=REPLACE_WITH_PRODUCTION_AUTH_SECRET_MIN_32_CHARS
API_INTERNAL_URL=https://api.corretoraavila.com.br

SEED_DEV_DATA=0

# Storage (quando habilitado)
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=insureflow-prod
# STORAGE_REGION=sa-east-1
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL=
