# Monorepo npm: hoist deps para o root (evita @nestjs/cli sem transitive deps)
install-strategy=hoisted
legacy-peer-deps=false

# Lockfile must list optional native binaries for all CI/deploy targets (lock was Windows-only).
supportedArchitectures.os=linux,win32,darwin
supportedArchitectures.cpu=x64,arm64
supportedArchitectures.libc=gnu,musl
