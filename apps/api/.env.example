# Copie para .env ou .env.local na raiz do monorepo / apps/api

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insureflow?schema=public

# Redis (BullMQ)
REDIS_URL=redis://127.0.0.1:6379
# Ou:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# JWT (mín. 32 caracteres em produção)
JWT_SECRET=dev-secret-min-32-chars-long-change-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

PORT=4000
CORS_ORIGIN=http://localhost:3000

# Rate limit global (Throttler)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Ownership enforcement (leads): off | shadow | on — sobrescreve Tenant.settings
# OWNERSHIP_ENFORCEMENT=shadow
