# InsureFlow — ambiente DEVELOPMENT (cloud dev: Neon + Railway + Vercel preview)
# Copie: cp .env.development.example .env.development

APP_ENV=development
NODE_ENV=production

# Neon — pooled para runtime API
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-pooler.us-east-2.aws.neon.tech/insureflow?sslmode=require

# Neon — direct para migrations (CI / release only)
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/insureflow?sslmode=require

# Redis (Railway Redis ou Upstash)
REDIS_URL=redis://default:PASSWORD@redis.railway.internal:6379

# JWT — gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_32_PLUS_CHAR_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

# API (Railway)
PORT=4000
CORS_ORIGIN=https://insureflow-web-dev.vercel.app,http://localhost:3000
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Next.js (Vercel)
AUTH_SECRET=REPLACE_WITH_32_PLUS_CHAR_SECRET
API_INTERNAL_URL=https://insureflow-api-dev.up.railway.app

# Seed permitido em dev cloud
SEED_DEV_DATA=1

# Storage (futuro)
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=insureflow-dev
# STORAGE_REGION=us-east-1
