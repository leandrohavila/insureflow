# Copie para .env na raiz do monorepo (usado por Prisma CLI e apps)

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insureflow?schema=public

# Redis (BullMQ) — apps/api
REDIS_URL=redis://127.0.0.1:6379

# JWT (mín. 32 caracteres em produção)
JWT_SECRET=dev-secret-min-32-chars-long-change-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

PORT=4000
CORS_ORIGIN=http://localhost:3000

THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Next.js (apps/web)
AUTH_SECRET=dev-auth-secret-min-32-chars-change-prod
API_INTERNAL_URL=http://localhost:4000
