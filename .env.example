# InsureFlow — referência rápida de variáveis (monorepo root)
# Ambientes específicos: veja .env.local.example | .env.development.example | etc.
# Documentação: docs/infra/environments.md

APP_ENV=local

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insureflow?schema=public
# Neon cloud (migrations): DATABASE_URL_DIRECT=...

# Redis (BullMQ) — apps/api
REDIS_URL=redis://127.0.0.1:6379

# JWT (mín. 32 caracteres em produção)
JWT_SECRET=dev-secret-min-32-chars-long-change-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=7

PORT=4000
CORS_ORIGIN=http://localhost:3000

THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Next.js (apps/web)
AUTH_SECRET=dev-auth-secret-min-32-chars-change-prod
API_INTERNAL_URL=http://localhost:4000

# Debug temporário do contrato Deal / pipelineOrder (opcional)
# DEAL_CONTRACT_DEBUG=1
# NEXT_PUBLIC_DEAL_CONTRACT_DEBUG=1

# Logs do lifecycle drag-and-drop no Kanban (dev)
# NEXT_PUBLIC_PIPELINE_DND_DEBUG=1

# Auditoria runtime API/BFF (DTO + ValidationPipe)
# RUNTIME_AUDIT=1
# DEAL_CONTRACT_DEBUG=1
